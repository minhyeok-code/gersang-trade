# .env.example — 이 파일을 복사해 .env로 만들고 값을 채우세요
# cp .env.example .env

# ── DB ────────────────────────────────────────────────────────────────────
DB_PASSWORD=qwer1234

# ── JWT (32자 이상 랜덤 문자열) ──────────────────────────────────────────
JWT_SECRET=gersang-trade-dev-secret-key-must-be-at-least-32-chars

# ── OAuth2 (로그인 기능 없이 테스트할 땐 비워도 됨) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ── AWS S3 (크롤러 사용 안 하면 비워도 됨) ────────────────────────────────
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=gersang-trade-images

# ── 운영 환경에서 반드시 설정 ─────────────────────────────────────────────
# OAUTH2_REDIRECT_URI=https://yourdomain.com/auth/callback
