# .env.example — 이 파일을 복사해 .env로 만들고 값을 채우세요
# cp .env.example .env

# ── DB ────────────────────────────────────────────────────────────────────
DB_PASSWORD=qwer1234

# ── JWT (32자 이상 랜덤 문자열) ──────────────────────────────────────────
JWT_SECRET=gersang-trade-dev-secret-key-must-be-at-least-32-chars

# ── OAuth2 (로그인 기능 없이 테스트할 땐 비워도 됨) ───────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# OAuth2 콜백 URL — 반드시 설정 (dev/prod 값 다름)
# dev:  OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback
# prod: OAUTH2_REDIRECT_URI=https://yourdomain.com/auth/callback
OAUTH2_REDIRECT_URI=http://localhost:3000/auth/callback

# ── AWS S3 ────────────────────────────────────────────────────────────────
# EC2에 IAM 역할 부여 시 ACCESS_KEY/SECRET_KEY 불필요 — 비워두면 IAM 역할 자동 사용
# 로컬 개발에서 S3 직접 테스트할 때만 값을 채운다
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_S3_BUCKET=gersang-trade-images

# ── dev 환경 오버라이드 (docker-compose-dev.yml 전용, 기본값 있음) ────────
# DDL_AUTO=create          # create | validate (Flyway 테스트 시 validate)
# FLYWAY_ENABLED=false     # true로 바꾸면 Flyway 마이그레이션 실행
# BATCH_SCHEMA_INIT=always # never로 바꾸면 Spring Batch 메타테이블 자동생성 안 함
# COOKIE_SECURE=false      # HTTPS 환경에서는 true
